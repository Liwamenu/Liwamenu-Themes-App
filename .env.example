# Copy to .env (committed defaults) or .env.local (gitignored overrides).

# ── API ───────────────────────────────────────────────────────
VITE_API_BASE_URL=https://your-backend.example.com
VITE_FALLBACK_TENANT=demo
VITE_USE_DUMMY_DATA=false

# ── Firebase Cloud Messaging ──────────────────────────────────
# Find these in Firebase Console > Project Settings > General.
# VAPID key is in Project Settings > Cloud Messaging > Web Push certificates.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
